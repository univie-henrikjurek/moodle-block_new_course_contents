{{!
    @template block_newcoursecontents/placeholder-course

    This template renders the loading placeholder for a card.
}}
<div class="col d-flex px-1">
    <div class="card h-100 w-100">
        <div class="card-img-top bg-pulse-grey" style="height: 100px;"></div>
        <div class="card-body">
            <div class="bg-pulse-grey mb-2" style="height: 1rem; width: 80%;"></div>
            <div class="bg-pulse-grey" style="height: 0.75rem; width: 60%;"></div>
        </div>
    </div>
</div>
