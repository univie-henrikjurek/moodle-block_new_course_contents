{{!
    @template block_newcoursecontents/nav-grouping-selector

    This template renders grouping dropdown.
}}
<div class="dropdown mb-1 me-1">
    <button id="groupingdropdown" type="button" class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" aria-label="{{#str}} aria:groupingdropdown, block_newcoursecontents {{/str}}">
        <span data-active-item-text>
            {{#allincludinghidden}}{{#str}} allincludinghidden, block_newcoursecontents {{/str}}{{/allincludinghidden}}
            {{#all}}{{#str}} all, block_newcoursecontents {{/str}}{{/all}}
            {{#inprogress}}{{#str}} inprogress, block_newcoursecontents {{/str}}{{/inprogress}}
            {{#future}}{{#str}} future, block_newcoursecontents {{/str}}{{/future}}
            {{#past}}{{#str}} past, block_newcoursecontents {{/str}}{{/past}}
            {{#favourites}}{{#str}} favourites, block_newcoursecontents {{/str}}{{/favourites}}
        </span>
    </button>
    <ul class="dropdown-menu" role="menu" data-show-active-item data-skip-active-class="true" data-active-item-text aria-labelledby="groupingdropdown">
        <li>
            <a class="dropdown-item" href="#" data-filter="grouping" data-value="allincludinghidden" data-pref="allincludinghidden" aria-label="{{#str}} aria:allcoursesincludinghidden, block_newcoursecontents {{/str}}" aria-controls="courses-view-{{uniqid}}" role="menuitem" {{#allincludinghidden}}aria-current="true"{{/allincludinghidden}}>
                {{#str}} allincludinghidden, block_newcoursecontents {{/str}}
            </a>
        </li>
        <li class="dropdown-divider" role="presentation">
            <span class="filler">&nbsp;</span>
        </li>
        <li>
            <a class="dropdown-item" href="#" data-filter="grouping" data-value="all" data-pref="all" aria-label="{{#str}} aria:allcourses, block_newcoursecontents {{/str}}" aria-controls="courses-view-{{uniqid}}" role="menuitem" {{#all}}aria-current="true"{{/all}}>
                {{#str}} all, block_newcoursecontents {{/str}}
            </a>
        </li>
        <li class="dropdown-divider" role="presentation">
            <span class="filler">&nbsp;</span>
        </li>
        <li>
            <a class="dropdown-item" href="#" data-filter="grouping" data-value="inprogress" data-pref="inprogress" aria-label="{{#str}} aria:inprogress, block_newcoursecontents {{/str}}" aria-controls="courses-view-{{uniqid}}" role="menuitem" {{#inprogress}}aria-current="true"{{/inprogress}}>
                {{#str}} inprogress, block_newcoursecontents {{/str}}
            </a>
        </li>
        <li>
            <a class="dropdown-item" href="#" data-filter="grouping" data-value="future" data-pref="future" aria-label="{{#str}} aria:future, block_newcoursecontents {{/str}}" aria-controls="courses-view-{{uniqid}}" role="menuitem" {{#future}}aria-current="true"{{/future}}>
                {{#str}} future, block_newcoursecontents {{/str}}
            </a>
        </li>
        <li>
            <a class="dropdown-item" href="#" data-filter="grouping" data-value="past" data-pref="past" aria-label="{{#str}} aria:past, block_newcoursecontents {{/str}}" aria-controls="courses-view-{{uniqid}}" role="menuitem" {{#past}}aria-current="true"{{/past}}>
                {{#str}} past, block_newcoursecontents {{/str}}
            </a>
        </li>
        <li class="dropdown-divider" role="presentation">
            <span class="filler">&nbsp;</span>
        </li>
        <li>
            <a class="dropdown-item" href="#" data-filter="grouping" data-value="favourites" data-pref="favourites" aria-label="{{#str}} aria:favourites, block_newcoursecontents {{/str}}" aria-controls="courses-view-{{uniqid}}" role="menuitem" {{#favourites}}aria-current="true"{{/favourites}}>
                {{#str}} favourites, block_newcoursecontents {{/str}}
            </a>
        </li>
    </ul>
</div>
