{{!
    @template block_newcoursecontents/courses-view

    This template renders the courses view for the newcoursecontents block.
}}
<div id="courses-view-{{uniqid}}"
    data-region="courses-view"
    data-display="{{view}}"
    data-grouping="{{grouping}}"
    data-sort="{{sort}}"
    data-prev-display="{{view}}"
    aria-live="polite"
    aria-atomic="false">
    <div data-region="course-view-content" role="region" aria-label="{{#str}} aria:courselist, block_newcoursecontents, {{#courses}}{{.}}{{/courses}}{{^courses}}0{{/courses}} {{/str}}">
        {{#isviewcard}}
            {{> block_newcoursecontents/view-cards }}
        {{/isviewcard}}
        {{#isviewlist}}
            {{> block_newcoursecontents/view-list }}
        {{/isviewlist}}
        {{^isviewcard}}
        {{^isviewlist}}
            {{> block_newcoursecontents/view-cards }}
        {{/isviewlist}}
        {{/isviewcard}}
    </div>
</div>
