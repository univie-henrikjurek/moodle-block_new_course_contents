<div class="block_newcoursecontents" data-region="newcoursecontents">
    <ul class="list-group">
    {{#courses}}
        <li class="list-group-item course-listitem border-start-0 border-end-0 border-top-0 px-2 rounded-0"
            data-ncc-courseid="{{{id}}}">
            <div class="row">
                <div class="col-md-2 d-flex align-items-center mb-sm-3 mb-md-0">
                    <a href="{{courseurl}}" tabindex="-1" class="mw-100 w-100">
                        <div class="rounded list-image mw-100" style='background-image: url("{{{courseimage}}}");'>
                            <span class="visually-hidden">{{fullname}}</span>
                        </div>
                    </a>
                </div>
                <div class="col-md-8 d-flex flex-column">
                    <div class="text-muted muted d-flex flex-wrap">
                        <span class="visually-hidden">{{#str}}aria:courseshortname, core_course {{/str}}</span>
                        <div>{{shortname}}</div>
                    </div>
                    <a href="{{courseurl}}" class="aalink coursename">
                        <span class="visually-hidden">{{#str}}aria:coursename, core_course {{/str}}</span>
                        {{{fullname}}}
                    </a>
                    {{#lastvisitstr}}
                    <div class="text-muted small">
                        <i class="fa-regular fa-eye me-1"></i>
                        {{#str}} lastvisit, block_newcoursecontents {{/str}}: {{lastvisitstr}}
                    </div>
                    {{/lastvisitstr}}
                    {{^lastvisitstr}}
                    <div class="text-muted small">
                        <i class="fa-regular fa-eye-slash me-1"></i>
                        {{#str}} nevervisited, block_newcoursecontents {{/str}}
                    </div>
                    {{/lastvisitstr}}
                    {{^visible}}
                    <div class="d-flex flex-wrap">
                        <span class="badge bg-info text-white">{{#str}} hiddenfromstudents {{/str}}</span>
                    </div>
                    {{/visible}}
                </div>
                <div class="col-md-2 d-flex align-items-center justify-content-end">
                    <div class="d-flex flex-row align-items-center gap-2">
                        {{#activitycount}}
                        <span class="badge rounded-pill px-3 py-2" style="background-color: {{badgecolor}};">
                            {{activitycount}} {{#str}} new, block_newcoursecontents {{/str}}
                        </span>
                        {{/activitycount}}
                        <a href="{{detailurl}}" class="btn btn-sm btn-outline-primary">
                            <i class="fa-solid fa-list me-1"></i>{{#str}} viewdetails, block_newcoursecontents {{/str}}
                        </a>
                    </div>
                </div>
            </div>
        </li>
    {{/courses}}
    </ul>

    {{^courses}}
    <div class="alert alert-info mb-0">
        <i class="fa-regular fa-inbox me-2"></i>
        {{#str}} nocourses, block_newcoursecontents {{/str}}
    </div>
    {{/courses}}
</div>
