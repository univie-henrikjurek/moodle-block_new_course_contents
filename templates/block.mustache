{{!
    @template block_newcoursecontents/block

    This template renders the block with filter controls.
}}
{{#js}}
// Inline script to set view preference before page render - prevents flash of wrong content
(function() {
    var key = 'block_newcoursecontents_view';
    var saved = localStorage.getItem(key);
    if (saved) {
        var el = document.querySelector('[data-region="courses-view"]');
        if (el) {
            el.setAttribute('data-display', saved);
        }
    }
})();
{{/js}}
<div id="block-newcoursecontents-{{uniqid}}" class="block-newcoursecontents" data-region="newcoursecontents" data-initial-view="{{view}}">
    <div data-region="filter" class="d-flex align-items-center my-2" aria-label="{{#str}} aria:controls, block_newcoursecontents {{/str}}">
        <div class="d-flex flex-wrap gap-1 align-items-center w-100">
            {{> block_newcoursecontents/nav-grouping-selector }}

            {{> block_newcoursecontents/nav-search-widget }}

            {{> block_newcoursecontents/nav-sort-selector }}

            {{#displaydropdown}}
                {{> block_newcoursecontents/nav-display-selector }}
            {{/displaydropdown}}
        </div>
    </div>

    <div class="container-fluid p-0">
        {{> block_newcoursecontents/courses-view }}
    </div>
</div>
{{#js}}
require(
[
    'jquery',
    'block_newcoursecontents/main',
],
function(
    $,
    Main
) {
    var root = $('#block-newcoursecontents-{{uniqid}}');
    Main.init(root);
});
{{/js}}
