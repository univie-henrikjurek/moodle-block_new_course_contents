{{!
    @template block_newcoursecontents/nav-search-widget

    This template renders the search input within the filters area.
}}
<div class="mb-1 me-1 flex-grow-1">
    <label class="visually-hidden" for="searchinput-{{uniqid}}">
        {{#str}} searchcourses, block_newcoursecontents {{/str}}
    </label>
    <div class="input-group">
        <span class="input-group-text bg-white">
            <button type="button" class="btn btn-link p-0 m-0 text-muted" data-action="clearsearch" aria-label="{{#str}} aria:clearsearch, block_newcoursecontents {{/str}}">
                <i class="fa fa-search" aria-hidden="true"></i>
            </button>
        </span>
        <input type="text" 
               class="form-control" 
               id="searchinput-{{uniqid}}"
               data-action="search"
               placeholder="{{#str}} search, core {{/str}}"
               aria-label="{{#str}} searchcourses, block_newcoursecontents {{/str}}">
    </div>
</div>
