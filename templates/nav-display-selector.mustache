{{!
    @template block_newcoursecontents/nav-display-selector

    This template renders display mode selector (card/list view).
}}
<div class="btn-group btn-group-sm ms-auto" role="group" aria-label="{{#str}} view, block_newcoursecontents {{/str}}">
    <input type="radio" class="btn-check" name="display" id="display-card-{{uniqid}}" value="card" {{#isviewcard}}checked{{/isviewcard}} autocomplete="off">
    <label class="btn btn-outline-secondary" for="display-card-{{uniqid}}" title="{{#str}} viewcard, block_newcoursecontents {{/str}}">
        <i class="fa fa-grip" aria-hidden="true"></i>
        <span class="sr-only">{{#str}} viewcard, block_newcoursecontents {{/str}}</span>
    </label>
    
    <input type="radio" class="btn-check" name="display" id="display-list-{{uniqid}}" value="list" {{#isviewlist}}checked{{/isviewlist}} autocomplete="off">
    <label class="btn btn-outline-secondary" for="display-list-{{uniqid}}" title="{{#str}} viewlist, block_newcoursecontents {{/str}}">
        <i class="fa fa-list" aria-hidden="true"></i>
        <span class="sr-only">{{#str}} viewlist, block_newcoursecontents {{/str}}</span>
    </label>
</div>
